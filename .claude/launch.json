{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "powershell",
      "runtimeArgs": ["-ExecutionPolicy", "Bypass", "-File", ".claude/run-api.ps1"],
      "port": 8080
    },
    {
      "name": "frontend",
      "runtimeExecutable": "powershell",
      "runtimeArgs": ["-ExecutionPolicy", "Bypass", "-File", ".claude/run-frontend.ps1"],
      "port": 3000
    },
    {
      "name": "website",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["-C", "../labflow_website", "dev", "--port", "3100"],
      "port": 3100
    }
  ]
}
